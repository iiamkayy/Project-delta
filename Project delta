local inv_last_key = false

local function should_show_inv()
    if not sg("delta_inv_enabled") then return false end
    local mode = sg("delta_inv_mode") or 0
    local key  = sgk("delta_inv_enabled")
    if key == 0 then key = 0x02 end
    if mode == 0 then return true
    elseif mode == 1 then
        local down = input.is_key_down(key)
        if down and not inv_last_key then inv_toggled = not inv_toggled end
        inv_last_key = down
        return inv_toggled
    else
        inv_last_key = false
        return input.is_key_down(key)
    end
end

local function get_closest_player_to_crosshair()
    if #cached_players == 0 then return nil end
    local sw, sh = draw.get_screen_size()
    local scx, scy = sw * 0.5, sh * 0.5
    local best, best_d = nil, math.huge
    for _, d in ipairs(cached_players) do
        local p = d.entity
        if p and p.is_valid and p.is_alive then
            local pos = p.position
            if pos then
                local sx, sy, vis = draw.world_to_screen(pos.x, pos.y, pos.z)
                if vis then
                    local dd = sqrt((sx-scx)^2 + (sy-scy)^2)
                    if dd < best_d then best_d = dd best = d end
                end
            end
        end
    end
    return best
end

local function draw_inv_panel()
    if not should_show_inv() then inv_panel.dragging = false return end
    handle_drag(inv_panel, inv_panel.w)

    local show_guns  = sg("delta_inv_show_guns")
    local show_armor = sg("delta_inv_show_armor")
    local show_val   = sg("delta_inv_show_val")
    local show_other = sg("delta_inv_show_other")
    local max_guns   = sg("delta_inv_max_guns")  or 10
    local max_armor  = sg("delta_inv_max_armor") or 10
    local max_val    = sg("delta_inv_max_val")   or 10
    local max_other  = sg("delta_inv_max_other") or 5

    local target = get_closest_player_to_crosshair()
    local equipped_item = nil
    local guns, armor, val, other = {}, {}, {}, {}
    if target then
        equipped_item = target.equipped
        for _, item in ipairs(target.inventory) do
            if is_valuable(item) then val[#val+1] = item
            elseif is_weapon(item) then guns[#guns+1] = item
            elseif is_armor(item) and target.worn[item] then armor[#armor+1] = item
            elseif not is_armor(item) then other[#other+1] = item end
        end
    end
    guns  = clamp_list(guns,  max_guns)
    armor = clamp_list(armor, max_armor)
    val   = clamp_list(val,   max_val)
    other = clamp_list(other, max_other)

    local ph = TITLE_H + PAD
    if equipped_item and equipped_item ~= "" then ph = ph + LINE_H_L + PAD + 14 end
    if show_guns  and #guns  > 0 then ph = ph + SEC_H + (#guns  * LINE_H_L) + 4 end
    if show_armor and #armor > 0 then ph = ph + SEC_H + (#armor * LINE_H_L) + 4 end
    if show_val   and #val   > 0 then ph = ph + SEC_H + (#val   * LINE_H_L) + 4 end
    if show_other and #other > 0 then ph = ph + SEC_H + (#other * LINE_H)   + 4 end
    if not target then ph = ph + LINE_H end
    ph = ph + PAD

    local px, py, pw = inv_panel.x, inv_panel.y, inv_panel.w
    draw_panel_frame(px, py, pw, ph, target and target.name or "Inventory Checker")
    local ly = py + TITLE_H + PAD

    if not target then
        draw.text(px+PAD, ly, "No players visible", COL.junk, FONT)
        return
    end

    if equipped_item and equipped_item ~= "" then
        local col = get_item_color(equipped_item)
        draw.text(px+PAD, ly, "EQUIPPED", COL.dim, 9)
        draw.text(px+PAD, ly+11, equipped_item, col, FONT_L)
        ly = ly + LINE_H_L + PAD
        draw.line(px+PAD, ly, px+pw-PAD, ly, COL.sec_line, 1)
        ly = ly + 4
    end
    if show_guns and #guns > 0 then
        ly = draw_section_header(px, ly, pw, "GUN(S)", COL.gun)
        for _, item in ipairs(guns) do draw.text(px+PAD+6, ly+2, item, COL.gun, FONT_L) ly = ly + LINE_H_L end
        ly = ly + 4
    end
    if show_armor and #armor > 0 then
        ly = draw_section_header(px, ly, pw, "ARMOR", COL.armor)
        for _, item in ipairs(armor) do draw.text(px+PAD+6, ly+2, item, COL.armor, FONT_L) ly = ly + LINE_H_L end
        ly = ly + 4
    end
    if show_val and #val > 0 then
        ly = draw_section_header(px, ly, pw, "VALUABLES", COL.val)
        for _, item in ipairs(val) do draw.text(px+PAD+6, ly+2, item, COL.val, FONT_L) ly = ly + LINE_H_L end
        ly = ly + 4
    end
    if show_other and #other > 0 then
        ly = draw_section_header(px, ly, pw, "OTHER", COL.junk)
        for _, item in ipairs(other) do draw.text(px+PAD+6, ly+2, item, COL.junk, FONT) ly = ly + LINE_H end
    end
end

local function hp_color(hp, max_hp)
    if max_hp <= 0 then return COL.none end
    local pct = hp / max_hp
    if pct > 0.5 then return COL.alive end
    if pct > 0.2 then return COL.warn end
    return COL.dead
end

local function draw_boss_panel()
    if not cfg.boss then boss_panel.dragging = false return end
    handle_drag(boss_panel, boss_panel.w)
    local ph = TITLE_H + SEC_H + (#boss_defs * LINE_H) + 4 + SEC_H + (#vehicle_defs * LINE_H) + 4 + PAD
    local px, py, pw = boss_panel.x, boss_panel.y, boss_panel.w
    draw_panel_frame(px, py, pw, ph, "Boss Tracker")
    local ly = py + TITLE_H
    ly = draw_section_header(px, ly, pw, "BOSSES", COL.accent)
    for i, entry in ipairs(boss_data) do
        local row_y = ly + (i-1) * LINE_H
        draw.text(px+PAD+4, row_y+3, entry.name, COL.white, FONT-1)
        local stxt, scol
        if entry.status == "alive" then
            local pct = entry.max_hp > 0 and math.floor(entry.hp / entry.max_hp * 100) or 0
            stxt = format("%d/%d (%d%%)", entry.hp, entry.max_hp, pct)
            if entry.dist >= 0 then stxt = stxt .. "  " .. entry.dist .. "m" end
            scol = hp_color(entry.hp, entry.max_hp)
        elseif entry.status == "dead" then stxt = "Dead" scol = COL.dead
        else stxt = "Not Spawned" scol = COL.none end
        local sw = draw.get_text_size(entry.name, FONT-1)
        draw.text(px+PAD+4+sw+6, row_y+3, stxt, scol, FONT-1)
    end
    ly = ly + (#boss_defs * LINE_H) + 4
    ly = draw_section_header(px, ly, pw, "VEHICLES", COL.accent)
    for i, entry in ipairs(vehicle_data) do
        local row_y = ly + (i-1) * LINE_H
        draw.text(px+PAD+4, row_y+3, entry.name, COL.white, FONT-1)
        local stxt, scol
        if entry.status == "spawned" then
            stxt = "Spawned"
            if entry.dist >= 0 then stxt = stxt .. "  " .. entry.dist .. "m" end
            scol = COL.vehicle
        else stxt = "Not Spawned" scol = COL.none end
        local sw = draw.get_text_size(entry.name, FONT-1)
        draw.text(px+PAD+4+sw+6, row_y+3, stxt, scol, FONT-1)
    end
end

-- World Loot Finder: nearby containers/corpses holding valuables
local function draw_wlf_panel()
    if not cfg.wlf then wlf_panel.dragging = false return end
    handle_drag(wlf_panel, wlf_panel.w)
    local mp = get_local_pos()
    local loot = {}
    if mp then
        local function scan_list(list, label)
            for _, item in ipairs(list) do
                if item.part and item.contents then
                    local ok, pos = pcall(function() return item.part.Position end)
                    if ok and pos then
                        local dist = get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z) * METERS_PER_STUD
                        local vals = {}
                        for _, c in ipairs(item.contents) do
                            if is_valuable(c) or is_weapon(c) then vals[#vals+1] = c end
                        end
                        if #vals > 0 then loot[#loot+1] = { name = item.name, label = label, dist = math.floor(dist), pos = pos, vals = vals } end
                    end
                end
            end
        end
        scan_list(world_cache.containers, "Container")
        scan_list(world_cache.corpses, "Corpse")
        table.sort(loot, function(a, b) return a.dist < b.dist end)
    end
    local shown = clamp_list(loot, 8)
    local px, py, pw = wlf_panel.x, wlf_panel.y, wlf_panel.w
    if #shown == 0 then
        draw_panel_frame(px, py, pw, TITLE_H + PAD + LINE_H + PAD, "World Loot Finder")
        draw.text(px+PAD, py+TITLE_H+PAD, "No valuable loot nearby", COL.dim, FONT-1)
        return
    end
    local ph = TITLE_H + PAD
    for _, l in ipairs(shown) do ph = ph + LINE_H + (#l.vals * 14) end
    ph = ph + PAD
    draw_panel_frame(px, py, pw, ph, "World Loot Finder")
    local ly = py + TITLE_H + PAD
    -- tracer to closest
    local sx, sy, vis = draw.world_to_screen(shown[1].pos.x, shown[1].pos.y, shown[1].pos.z)
    if vis then
        local sw, sh = draw.get_screen_size()
        draw.line(sw*0.5, sh*0.5, sx, sy, {0.35, 0.9, 0.45, 0.4}, 1)
    end
    for _, l in ipairs(shown) do
        draw.text(px+PAD, ly, l.label .. ": " .. l.name .. " [" .. l.dist .. "m]", COL.val, FONT-1)
        ly = ly + LINE_H
        for _, v in ipairs(l.vals) do
            draw.text(px+PAD+PAD, ly, v, get_item_color(v), 11)
            ly = ly + 14
        end
    end
end

