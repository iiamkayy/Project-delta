-- NO RECOIL (pattern zero) + RAPID FIRE (GC)
-- =====================================================================
local RECOIL_PATTERN_NAMES = { "RecoilPattern", "RecoilPatternOLD", "RecoilPattern2", "RecoilPattern3", "RecoilPatternDisabled" }

local function zero_recoil_patterns()
    local rep = game.get_service("ReplicatedStorage")
    if not rep then return end
    local rw = rep:find_first_child("RangedWeapons")
    if not rw then return end
    local ok, weapons = pcall(function() return rw:get_children() end)
    if not ok or not weapons then return end
    for i = 1, #weapons do
        local w = weapons[i]
        for n = 1, #RECOIL_PATTERN_NAMES do
            local p = w:find_first_child(RECOIL_PATTERN_NAMES[n])
            if p then
                local ok2, shots = pcall(function() return p:get_children() end)
                if ok2 and shots then
                    for j = 1, #shots do
                        local xv = shots[j]:find_first_child("x")
                        local yv = shots[j]:find_first_child("y")
                        if xv then pcall(function() xv.Value = 0 end) end
                        if yv then pcall(function() yv.Value = 0 end) end
                    end
                end
            end
        end
    end
end

