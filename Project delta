    end
    -- Containers
    local cont=ws:find_first_child("Containers")
    if cont then
        local ok,ch=pcall(function()return cont:get_children()end)
        if ok and ch then
            for i=1,#ch do
                local child=ch[i]
                local models=child.class_name=="Folder" and (function() local o2,s=pcall(function()return child:get_children()end) return o2 and s or{} end)() or {child}
                for j=1,#models do
                    local m=models[j]
                    if m.class_name=="Model" and m.name~="" then
                        local part=get_root(m)
                        if part then
                            world_cache.containers[#world_cache.containers+1]={name=m.name,part=part,contents=get_inv_contents(m)}
                        end
                    end
                end
            end
        end
    end
    -- Quests
    local quests=ws:find_first_child("QuestItems")
    if quests then
        local ok,ch=pcall(function()return quests:get_children()end)
        if ok and ch then
            for i=1,#ch do
                local child=ch[i]
                local models=child.class_name=="Folder" and (function() local o2,s=pcall(function()return child:get_children()end) return o2 and s or{} end)() or {child}
                for j=1,#models do
                    local m=models[j]
                    if m.class_name=="Model" and m.name~="" then
                        local part=get_root(m)
                        if part then world_cache.quests[#world_cache.quests+1]={name=m.name,part=part} end
                    end
