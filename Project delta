local function get_part_box(part)
    if not part or not utility.is_valid(part) then return nil end
    local pos = part.Position
    local size = part.Size
    if not pos or not size then return nil end
    local rx,ry,rz, ux,uy,uz, lx,ly,lz = 1,0,0, 0,1,0, 0,0,1
    local ok_r, rot = pcall(function() return part.Rotation end)
    if ok_r and rot and type(rot) == "table" and rot[1] and type(rot[1]) == "table" then
        rx,ry,rz = rot[1][1] or 1, rot[2][1] or 0, rot[3][1] or 0
        ux,uy,uz = rot[1][2] or 0, rot[2][2] or 1, rot[3][2] or 0
        lx,ly,lz = -(rot[1][3] or 0), -(rot[2][3] or 0), -(rot[3][3] or 0)
    end
    return {
        x=pos.x, y=pos.y, z=pos.z,
        hx=size.x*0.5, hy=size.y*0.5, hz=size.z*0.5,
        rx=rx,ry=ry,rz=rz, ux=ux,uy=uy,uz=uz, lx=lx,ly=ly,lz=lz,
    }
end

local function get_model_bounds(model)
    local mnx,mny,mnz = math.huge, math.huge, math.huge
    local mxx,mxy,mxz = -math.huge, -math.huge, -math.huge
    local any = false
    for j = 1, #BONE_NAMES do
        local ok, part = pcall(function() return model:find_first_child(BONE_NAMES[j]) end)
        if ok and part then
            local ok2, pos = pcall(function() return part.Position end)
            local ok3, sz  = pcall(function() return part.Size end)
            if ok2 and pos and ok3 and sz then
                any = true
                local hx,hy,hz = sz.x*0.5, sz.y*0.5, sz.z*0.5
                mnx=math.min(mnx,pos.x-hx); mny=math.min(mny,pos.y-hy); mnz=math.min(mnz,pos.z-hz)
                mxx=math.max(mxx,pos.x+hx); mxy=math.max(mxy,pos.y+hy); mxz=math.max(mxz,pos.z+hz)
            end
        end
    end
    if not any then return nil end
    return {
        {mnx,mny,mnz},{mxx,mny,mnz},{mnx,mxy,mnz},{mxx,mxy,mnz},
        {mnx,mny,mxz},{mxx,mny,mxz},{mnx,mxy,mxz},{mxx,mxy,mxz},
    }
end

local function project_corners(corners)
    local sc, n = {}, 0
    for i = 1, 8 do
        local c = corners[i]
        local sx, sy, vis = draw.world_to_screen(c[1], c[2], c[3])
        if vis then sc[i] = { x = sx, y = sy } n = n + 1 end
    end
    return sc, n
end

local function draw_3d_box(corners, col, thick)
    local sc = project_corners(corners)
    for _, e in ipairs(BOX_EDGES) do
        local a, b = sc[e[1]], sc[e[2]]
        if a and b then draw.line(a.x, a.y, b.x, b.y, col, thick or 1) end
    end
end

local function draw_3d_corner_box(corners, col, thick)
    local sc = project_corners(corners)
    for _, e in ipairs(CORNER_EDGES) do
        local a, b = sc[e[1]], sc[e[2]]
        if a and b then draw.line(a.x, a.y, b.x, b.y, col, thick or 1) end
    end
end

local function draw_oriented_box(box, col, thick)
    local corners = {}
    for i = 1, 8 do
        local sx, sy, sz = BOX_SIGNS[i][1], BOX_SIGNS[i][2], BOX_SIGNS[i][3]
        local lx, ly, lz = sx*box.hx, sy*box.hy, sz*box.hz
        corners[i] = {
            box.x + box.rx*lx + box.ux*ly + box.lx*lz,
            box.y + box.ry*lx + box.uy*ly + box.ly*lz,
            box.z + box.rz*lx + box.uz*ly + box.lz*lz,
        }
    end
    draw_3d_box(corners, col, thick)
end

local function get_box_anchors(corners)
    local tx,ty,tn = 0, math.huge, 0
    local bx,by,bn = 0, -math.huge, 0
    local lx,lmin,lmax,ln = 0, math.huge, -math.huge, 0
    for i = 5, 8 do
        local sx, sy, vis = draw.world_to_screen(corners[i][1], corners[i][2], corners[i][3])
        if vis then tx = tx + sx; ty = math.min(ty, sy); tn = tn + 1 end
    end
    if tn > 0 then tx = tx / tn end
    for i = 1, 4 do
        local sx, sy, vis = draw.world_to_screen(corners[i][1], corners[i][2], corners[i][3])
        if vis then bx = bx + sx; by = math.max(by, sy); bn = bn + 1 end
    end
    if bn > 0 then bx = bx / bn end
    for _, i in ipairs({1,3,5,7}) do
        local sx, sy, vis = draw.world_to_screen(corners[i][1], corners[i][2], corners[i][3])
        if vis then lx = lx + sx; lmin = math.min(lmin, sy); lmax = math.max(lmax, sy); ln = ln + 1 end
    end
    if ln > 0 then lx = lx / ln end
    return { top={x=tx,y=ty,vis=tn>0}, bot={x=bx,y=by,vis=bn>0}, left={x=lx,miny=lmin,maxy=lmax,vis=ln>0} }
end

