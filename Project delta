-- Loot Finder
local function draw_slf_panel()
    if not cfg.slf then slf_panel.dragging=false return end
    local mx,my=utility.get_mouse_pos(); local lmb=input.is_key_down(0x01)
    if lmb then start_drag(slf_panel,mx,my,slf_panel.w) else slf_panel.dragging=false end
    local me=entity.get_local_player(); local mp=me and me.position
    if not mp then return end
    local loot={}
    local function scan_list(list,label)
        for _,item in ipairs(list) do
            if item.part then
                local ok,pos=pcall(function()return item.part.Position end)
                if ok and pos then
                    local dist=math.floor(get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z))
                    local vals={}
                    if item.contents then
                        for _,c in ipairs(item.contents) do
                            if is_valuable(c) or is_weapon(c) then vals[#vals+1]=c end
                        end
                    end
                    if #vals>0 then loot[#loot]={name=item.name,label=label,dist=dist,pos=pos,vals=vals} end
                end
            end
        end
    end
    scan_list(world_cache.containers,"Container")
    scan_list(world_cache.corpses,"Corpse")
    table.sort(loot,function(a,b) return a.dist<b.dist end)
    local shown={}
    for i=1,math.min(#loot,8) do shown[i]=loot[i] end
    if #shown==0 then
        local px,py,pw=slf_panel.x,slf_panel.y,slf_panel.w
        draw_panel_frame(px,py,pw,24+10+16+10,"Loot Finder")
        draw.text(px+10,py+34,"No valuable loot nearby",PANEL_DIM,12)
        return
    end
    local ph=24+10
    for _,l in ipairs(shown) do ph=ph+16+(#l.vals*14) end
    ph=ph+10
    local px,py,pw=slf_panel.x,slf_panel.y,slf_panel.w
    draw_panel_frame(px,py,pw,ph,"Loot Finder")
    local ly=py+34
    -- Draw tracer to closest
    if shown[1].pos then
        local sx,sy,vis=draw.world_to_screen(shown[1].pos.x,shown[1].pos.y,shown[1].pos.z)
        if vis then
            local sw,sh=draw.get_screen_size()
            draw.line(sw*0.5,sh*0.5,sx,sy,{0.35,0.9,0.45,0.4},1)
        end
    end
    for _,l in ipairs(shown) do
        draw.text(px+10,ly,l.label..": "..l.name.." ["..l.dist.."m]",{0.35,0.9,0.45,1},12)
        ly=ly+16
        for _,v in ipairs(l.vals) do
            draw.text(px+20,ly,v,get_item_color(v),11)
            ly=ly+14
        end
    end
end

