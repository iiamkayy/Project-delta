local function start_drag(panel, mx, my, pw, title_h)
    if not panel.dragging then
        if mx >= panel.x and mx <= panel.x + pw and my >= panel.y and my <= panel.y + title_h then
            panel.dragging = true
            panel.drag_ox = mx - panel.x
            panel.drag_oy = my - panel.y
        end
    else
        panel.x = mx - panel.drag_ox
        panel.y = my - panel.drag_oy
    end
end

local function handle_drag(panel, pw, title_h)
    local mx, my = utility.get_mouse_pos()
    local lmb = input.is_key_down(0x01)
    if lmb then start_drag(panel, mx, my, pw, title_h or TITLE_H)
    else panel.dragging = false end
end

local function draw_panel_frame(px, py, pw, ph, title)
    draw.rect(px-1, py-1, pw+2, ph+2, {0.18, 0.72, 0.84, 0.15}, 5, 1)
    draw.rect_filled(px, py, pw, ph, COL.bg, 4)
    draw.rect_filled(px, py, pw, TITLE_H, COL.title, 4)
    draw.rect_filled(px, py, 2, TITLE_H, COL.border, 0)
    draw.line(px, py+TITLE_H, px+pw, py+TITLE_H, COL.border, 1)
    draw.rect(px, py, pw, ph, {0.18, 0.72, 0.84, 0.5}, 4, 1)
    draw.text(px+PAD, py+5, title, COL.accent, FONT)
    local hw = draw.get_text_size("drag ::", 10)
    draw.text(px+pw-hw-PAD, py+6, "drag ::", COL.dim, 10)
end

local function draw_section_header(px, ly, pw, label, col)
    draw.rect_filled(px, ly, pw, SEC_H, COL.sec_bg, 0)
    draw.rect_filled(px, ly, 2, SEC_H, col, 0)
    draw.line(px, ly+SEC_H, px+pw, ly+SEC_H, COL.sec_line, 1)
    local tw = draw.get_text_size(label, 10)
    draw.text(px + (pw-tw)*0.5, ly+4, label, col, 10)
    return ly + SEC_H
end

local function clamp_list(list, max_n)
    if #list <= max_n then return list end
    local out = {}
    for i = 1, max_n do out[i] = list[i] end
    return out
end

