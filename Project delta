    local col = cfg.crosshair_col_on and cfg.crosshair_col or {1, 1, 1, 1}
    local outline = cfg.crosshair_outline
    local oc = {0, 0, 0, 1}
    if style == 0 then
        if outline then draw.rect_filled(cx-th-1, cy-th-1, th*2+2, th*2+2, oc, 0) end
        draw.rect_filled(cx-th, cy-th, th*2, th*2, col, 0)
    elseif style == 1 then
        if outline then
            draw.line(cx-sz, cy, cx+sz, cy, oc, th+2)
            draw.line(cx, cy-sz, cx, cy+sz, oc, th+2)
        end
        draw.line(cx-sz, cy, cx+sz, cy, col, th)
        draw.line(cx, cy-sz, cx, cy+sz, col, th)
    elseif style == 2 then
        if outline then draw.circle(cx, cy, sz, oc, 48, th+2) end
        draw.circle(cx, cy, sz, col, 48, th)
    elseif style == 3 then
        if outline then
            draw.line(cx-sz, cy, cx+sz, cy, oc, th+2)
            draw.line(cx, cy-sz, cx, cy+sz, oc, th+2)
        end
        draw.line(cx-sz, cy, cx+sz, cy, col, th)
        draw.line(cx, cy-sz, cx, cy+sz, col, th)
        if outline then draw.circle(cx, cy, sz, oc, 48, th+2) end
        draw.circle(cx, cy, sz, col, 48, th)
    end
end

