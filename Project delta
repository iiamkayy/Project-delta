    -- Extracts
    local no_col=ws:find_first_child("NoCollision")
    if no_col then
        local exits=no_col:find_first_child("ExitLocations")
        if exits then
            local ok,ch=pcall(function()return exits:get_children()end)
            if ok and ch then
                for i=1,#ch do
