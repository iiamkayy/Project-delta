-- Inventory Viewer
local function should_show_inv()
    if not sg("delta_inv_enabled") then return false end
    local mode=sg("delta_inv_mode")or 0
    local key=sgk("delta_inv_enabled") if key==0 then key=2 end
    if mode==0 then return true
    elseif mode==1 then
        local down=input.is_key_down(key)
        if down and not inv_last_key then inv_toggled=not inv_toggled end
        inv_last_key=down; return inv_toggled
    else inv_last_key=false; return input.is_key_down(key) end
end

local function draw_inv_panel()
    if not should_show_inv() then inv_panel.dragging=false return end
    local mx,my=utility.get_mouse_pos(); local lmb=input.is_key_down(0x01)
    if lmb then start_drag(inv_panel,mx,my,inv_panel.w) else inv_panel.dragging=false end
    scan_players_inv()
    local target=nil
    if #cached_players>0 then
        local sw,sh=draw.get_screen_size(); local scx,scy=sw*0.5,sh*0.5
        local best,best_d=nil,math.huge
        for _,d in ipairs(cached_players) do
            local p=d.entity
            if p and p.is_valid and p.is_alive then
                local pos=p.position
                if pos then
                    local sx,sy,vis=draw.world_to_screen(pos.x,pos.y,pos.z)
                    if vis then
                        local dx,dy=sx-scx,sy-scy; local dd=sqrt(dx*dx+dy*dy)
                        if dd<best_d then best_d=dd; target=d end
                    end
                end
            end
        end
    end
    local guns,armor,val,other={},{},{}
    if target then
        for _,item in ipairs(target.inventory) do
            if is_valuable(item) then val[#val+1]=item
            elseif is_weapon(item) then guns[#guns+1]=item
            elseif is_armor(item) and target.worn[item] then armor[#armor+1]=item
            elseif not is_armor(item) then other[#other+1]=item end
        end
    end
    local mg=sg("delta_inv_max_guns")or 10; local ma=sg("delta_inv_max_armor")or 10
    local mv=sg("delta_inv_max_val")or 10; local mo=sg("delta_inv_max_other")or 5
    if #guns>mg then local t={}; for i=1,mg do t[i]=guns[i] end; guns=t end
    if #armor>ma then local t={}; for i=1,ma do t[i]=armor[i] end; armor=t end
    if #val>mv then local t={}; for i=1,mv do t[i]=val[i] end; val=t end
    if #other>mo then local t={}; for i=1,mo do t[i]=other[i] end; other=t end
    local ph=24+10
    if target and target.equipped and target.equipped~="" then ph=ph+36 end
    if sg("delta_inv_show_guns") and #guns>0 then ph=ph+18+(#guns*20)+4 end
    if sg("delta_inv_show_armor") and #armor>0 then ph=ph+18+(#armor*20)+4 end
    if sg("delta_inv_show_val") and #val>0 then ph=ph+18+(#val*20)+4 end
    if sg("delta_inv_show_other") and #other>0 then ph=ph+18+(#other*16)+4 end
    if not target then ph=ph+16 end
    ph=ph+10
    local px,py,pw=inv_panel.x,inv_panel.y,inv_panel.w
    draw_panel_frame(px,py,pw,ph,target and target.name or "Inventory Checker")
    local ly=py+24+10
    if not target then draw.text(px+10,ly,"No players visible",PANEL_DIM,13); return end
    if target.equipped and target.equipped~="" then
        draw.text(px+10,ly,"EQUIPPED",PANEL_DIM,9)
        draw.text(px+10,ly+11,target.equipped,get_item_color(target.equipped),14)
        ly=ly+36; draw.line(px+10,ly,px+pw-10,ly,SEC_LINE,1); ly=ly+4
    end
    if sg("delta_inv_show_guns") and #guns>0 then
        ly=draw_sec_header(px,ly,pw,"GUNS",{0.95,0.3,0.3,1})
        for _,item in ipairs(guns) do draw.text(px+16,ly+2,item,{0.95,0.3,0.3,1},14); ly=ly+20 end
        ly=ly+4
    end
    if sg("delta_inv_show_armor") and #armor>0 then
        ly=draw_sec_header(px,ly,pw,"ARMOR",{0.18,0.72,0.84,1})
        for _,item in ipairs(armor) do draw.text(px+16,ly+2,item,{0.18,0.72,0.84,1},14); ly=ly+20 end
        ly=ly+4
    end
    if sg("delta_inv_show_val") and #val>0 then
        ly=draw_sec_header(px,ly,pw,"VALUABLES",{0.35,0.9,0.45,1})
        for _,item in ipairs(val) do draw.text(px+16,ly+2,item,{0.35,0.9,0.45,1},14); ly=ly+20 end
        ly=ly+4
    end
    if sg("delta_inv_show_other") and #other>0 then
        ly=draw_sec_header(px,ly,pw,"OTHER",{0.4,0.4,0.45,1})
        for _,item in ipairs(other) do draw.text(px+16,ly+2,item,PANEL_DIM,13); ly=ly+16 end
    end
end

