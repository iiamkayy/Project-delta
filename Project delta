local frame = 0

-- initial warm-up scans
pcall(scan_players_inv)
pcall(refresh_npcs)
pcall(refresh_world)
pcall(update_bosses)
pcall(scan_mods)
pcall(scan_player_loot)

function on_frame()
    frame = frame + 1

    -- throttled background scans (positions are read live; lists refresh on a timer)
    if frame % 6  == 0 then pcall(scan_players_inv) end
    if frame % 12 == 0 then pcall(refresh_npcs); pcall(refresh_world) end
    if frame % 30 == 0 then pcall(scan_player_loot) end
    if frame % 60 == 0 then pcall(update_bosses); pcall(scan_mods) end

    pcall(cache_settings)

    draw_watermark()
    draw_crosshair()
    process_aimbot()

    local mp = get_local_pos()

    -- Player ESP
    if cfg.player then
        local players = entity.get_players()
        if players then
            for i = 1, #players do
                local p = players[i]
                if p and p.is_valid and not p.is_local and p.is_alive then
                    local char = game.workspace:find_first_child(p.name)
                    if char then
                        local hum  = char:find_first_child_of_class("Humanoid")
                        local root = char:find_first_child("HumanoidRootPart")
                        if hum and root then
                            local dist_m = 0
                            if mp then
                                local ok, pos = pcall(function() return root.Position end)
                                if ok and pos then dist_m = math.floor(get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z) * METERS_PER_STUD) end
                            end
                            if dist_m <= cfg.player_range then
                                draw_character_esp(char, p.name, hum, root, {
                                    box = cfg.player_box, box_col = cfg.player_box_col, box_style = cfg.player_box_style,
                                    skeleton = cfg.player_skel, skel_col = cfg.player_skel_col,
                                    health = cfg.player_hp, name = cfg.player_name, name_col = cfg.player_name_col,
                                    dist = cfg.player_dist, dist_col = cfg.player_dist_col, dist_m = dist_m,
                                    tracers = cfg.player_tracers, tracer_col = cfg.player_tracer_col,
                                })
                            end
                        end
                    end
                end
            end
        end
    end

    -- NPC ESP
    if cfg.npc then
        for _, npc in ipairs(npc_cache) do
            local root = npc.model:find_first_child("HumanoidRootPart")
            local dist_m = 0
            if mp and root then
                local ok, pos = pcall(function() return root.Position end)
                if ok and pos then dist_m = math.floor(get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z) * METERS_PER_STUD) end
            end
            if dist_m <= cfg.npc_range then
                draw_character_esp(npc.model, npc.model.name, npc.hum, root, {
                    box = cfg.npc_box, box_col = cfg.npc_box_col, box_style = cfg.npc_box_style,
                    skeleton = cfg.npc_skel, skel_col = cfg.npc_skel_col,
                    health = cfg.npc_hp, name = cfg.npc_name, name_col = cfg.npc_name_col,
                    dist = cfg.npc_dist, dist_col = cfg.npc_dist_col, dist_m = dist_m,
                    tracers = false,
                })
            end
        end
    end

    -- World ESP
    if cfg.extract   then for _, it in ipairs(world_cache.extracts)    do draw_world_item(it, cfg.extract_range,   cfg.extract_col,   cfg.extract_box,   nil) end end
    if cfg.container then for _, it in ipairs(world_cache.containers)  do draw_world_item(it, cfg.container_range, cfg.container_col, cfg.container_box, cfg.container_contents and it.contents or nil) end end
    if cfg.quest     then for _, it in ipairs(world_cache.quests)      do draw_world_item(it, cfg.quest_range,     cfg.quest_col,     cfg.quest_box,     nil) end end
    if cfg.items     then for _, it in ipairs(world_cache.items)       do draw_world_item(it, cfg.items_range,     cfg.items_col,     cfg.items_box,     nil) end end
    if cfg.corpse    then for _, it in ipairs(world_cache.corpses)     do draw_world_item(it, cfg.corpse_range,    cfg.corpse_col,    cfg.corpse_box,    cfg.corpse_contents and it.contents or nil) end end
    draw_claymores()

    -- Panels
    draw_inv_panel()
    draw_boss_panel()
    draw_wlf_panel()
    draw_plf_panel()
    draw_mod_panel()
end

