local function refresh_world()
    world_cache = { extracts={}, items={}, corpses={}, containers={}, quests={}, claymores={} }
    local ws = game.workspace
    if not ws then return end

    -- Extracts
    local no_col = ws:find_first_child("NoCollision")
    local exits  = no_col and no_col:find_first_child("ExitLocations")
    if exits then
        local ok, ch = pcall(function() return exits:get_children() end)
        if ok and ch then
            for i = 1, #ch do
                local c = ch[i]
                local part = c:is_a("BasePart") and c or get_root(c)
                if part then world_cache.extracts[#world_cache.extracts+1] = { name = c.name, part = part } end
            end
        end
    end

    -- Drops (items + corpses)
    local drops = ws:find_first_child("DroppedItems")
    if drops then
        local ok, ch = pcall(function() return drops:get_children() end)
        if ok and ch then
            for i = 1, #ch do
                local function add_models(models)
                    for j = 1, #models do
                        local m = models[j]
                        if m.class_name == "Model" and m.name ~= "" then
                            local part = get_root(m)
                            if part then
                                local is_body = false
                                local nl = m.name:lower()
                                if nl:find("bodybag") or nl:find("corpse") or nl:find("dead") then
                                    is_body = true
                                else
                                    local hum = m:find_first_child_of_class("Humanoid")
                                    if hum then
                                        local okh, hp = pcall(function() return hum.Health end)
                                        if okh and hp and hp <= 0 then is_body = true end
                                    end
                                end
                                if is_body then
                                    world_cache.corpses[#world_cache.corpses+1] = { name = m.name, part = part, contents = get_inv_contents(m) }
                                else
                                    world_cache.items[#world_cache.items+1] = { name = m.name, part = part }
                                end
                            end
                        end
                    end
                end
                if ch[i].class_name == "Folder" then
                    local ok2, sub = pcall(function() return ch[i]:get_children() end)
                    if ok2 and sub then add_models(sub) end
                else
                    add_models({ ch[i] })
                end
            end
        end
    end

    -- Containers
    local cont = ws:find_first_child("Containers")
    if cont then
        local ok, ch = pcall(function() return cont:get_children() end)
        if ok and ch then
            for i = 1, #ch do
                local function add_models(models)
                    for j = 1, #models do
                        local m = models[j]
                        if m.class_name == "Model" and m.name ~= "" then
                            local part = get_root(m)
                            if part then
                                world_cache.containers[#world_cache.containers+1] = { name = m.name, part = part, contents = get_inv_contents(m) }
                            end
                        end
                    end
                end
                if ch[i].class_name == "Folder" then
                    local ok2, sub = pcall(function() return ch[i]:get_children() end)
                    if ok2 and sub then add_models(sub) end
                else
                    add_models({ ch[i] })
                end
            end
        end
    end

    -- Quests
    local qf = ws:find_first_child("QuestItems")
    if qf then
        local ok, ch = pcall(function() return qf:get_children() end)
        if ok and ch then
            for i = 1, #ch do
                local function add_models(models)
                    for j = 1, #models do
                        local m = models[j]
                        if m.class_name == "Model" and m.name ~= "" then
                            local part = get_root(m)
                            if part then world_cache.quests[#world_cache.quests+1] = { name = m.name, part = part } end
                        end
                    end
                end
                if ch[i].class_name == "Folder" then
                    local ok2, sub = pcall(function() return ch[i]:get_children() end)
                    if ok2 and sub then add_models(sub) end
                else
                    add_models({ ch[i] })
                end
            end
        end
    end

    -- Claymores (precise: AiZones.Claymores -> MON50)
    local ai_zones = ws:find_first_child("AiZones")
    local clay_folder = ai_zones and ai_zones:find_first_child("Claymores")
    if clay_folder then
        local ok, ch = pcall(function() return clay_folder:get_children() end)
        if ok and ch then
            for i = 1, #ch do
                local m = ch[i]
                if m.name == "MON50" then
                    local mine = m:find_first_child("MeshPart") or get_root(m)
                    local trig = m:find_first_child("Trigger")
                    if mine then world_cache.claymores[#world_cache.claymores+1] = { name = "Claymore", part = mine, trigger = trig } end
                end
            end
        end
    end
end

-- Thorough player inventory scan (from the working v2 script)
local function scan_players_inv()
    local result = {}
    local players = entity.get_players()
    if not players then cached_players = result return end
    local rep = game.get_service("ReplicatedStorage")
    local rep_players = rep and rep:find_first_child("Players")
    local ws = game.workspace
    for i = 1, #players do
        local p = players[i]
        if p and p.is_valid and not p.is_local then
            local pname = p.name or ""
            local puid  = tostring(p.user_id or "")
            local inv, worn, seen = {}, {}, {}
            local equipped = nil
            local function add(name, is_top)
                if name and name ~= "" and not seen[name] then
                    seen[name] = true
                    inv[#inv+1] = name
                    if is_top then worn[name] = true end
                end
            end
            local function scan_folder(folder, depth)
                if not folder then return end
                if depth and depth > 8 then return end
                local ok2, items = pcall(function() return folder:get_children() end)
                if not ok2 or not items then return end
                for j = 1, #items do
                    local item = items[j]
                    local n = item.name or ""
                    if n ~= "" then add(n, depth == 0) end
                    local ok3, ch = pcall(function() return item:get_children() end)
                    if ok3 and ch and #ch > 0 then scan_folder(item, (depth or 0) + 1) end
                end
            end
            if rep_players then
                local data = rep_players:find_first_child(pname)
                if not data and puid ~= "" then data = rep_players:find_first_child(puid) end
                if not data then
                    local ok2, folders = pcall(function() return rep_players:get_children() end)
                    if ok2 and folders then
                        for _, f in ipairs(folders) do
                            if f.name == pname or f.name == puid then data = f break end
                        end
                    end
                end
                if data then
                    scan_folder(data:find_first_child("Inventory"), 0)
                    local status = data:find_first_child("Status")
                    if status then
                        local gv = status:find_first_child("GameplayVariables")
                        if gv then
                            local eq = gv:find_first_child("EquippedTool")
                            if eq and eq.Value then
                                local v = eq.Value
                                if type(v) == "string" and v ~= "" then equipped = v
                                elseif type(v) == "userdata" then equipped = v.name end
                            end
                        end
                    end
                end
            end
            -- also pull holstered tools + worn clothing from the workspace character
            local wchar = ws and ws:find_first_child(pname)
            if wchar and wchar:is_a("Model") then
                local holstered = wchar:find_first_child("Holstered")
                if holstered then
                    local ok2, items = pcall(function() return holstered:get_children() end)
                    if ok2 and items then
                        for cj = 1, #items do
                            local v = items[cj].Value
                            local iname = v and (v.name or tostring(v)) or ""
                            if iname ~= "" then add(iname, false) end
                        end
                    end
                end
                local clothing = wchar:find_first_child("Clothing")
                if clothing then
                    local ok2, items = pcall(function() return clothing:get_children() end)
                    if ok2 and items then
                        for cj = 1, #items do
                            local v = items[cj].Value
                            local iname = v and (v.name or tostring(v)) or ""
                            if iname ~= "" then add(iname, true) end
                        end
                    end
                end
            end
            result[#result+1] = { name = pname, entity = p, inventory = inv, worn = worn, equipped = equipped }
        end
    end
    cached_players = result
end

local function update_bosses()
    local ws = game.workspace
    if not ws then return end
    local ai_zones = ws:find_first_child("AiZones")
    local me = entity.get_local_player()
    local mp = me and me.position
    for i, def in ipairs(boss_defs) do
        local entry = { name = def.name, status = "none", hp = 0, max_hp = 0, dist = -1 }
        if ai_zones then
            local zone = ai_zones:find_first_child(def.zone)
            local boss = zone and zone:find_first_child(def.name)
            if boss then
                local hum = boss:find_first_child_of_class("Humanoid")
                if hum then
                    local okh, hp = pcall(function() return hum.Health end)
                    local okm, mhp = pcall(function() return hum.MaxHealth end)
                    if okh and hp and hp > 0 then
                        entry.status = "alive"
                        entry.hp = math.floor(hp)
                        entry.max_hp = math.floor(okm and mhp or 100)
                        local hrp = boss:find_first_child("HumanoidRootPart")
                        if mp and hrp then
                            local okp, bp = pcall(function() return hrp.Position end)
                            if okp and bp then entry.dist = math.floor(get_dist(mp.x,mp.y,mp.z,bp.x,bp.y,bp.z) * METERS_PER_STUD) end
                        end
                    else entry.status = "dead" end
                else entry.status = "dead" end
            end
        end
        boss_data[i] = entry
    end
    for i, def in ipairs(vehicle_defs) do
        local entry = { name = def.label, status = "none", dist = -1 }
        local veh = ws:find_first_child(def.name)
        if not veh and ai_zones then
            local ok2, zones = pcall(function() return ai_zones:get_children() end)
            if ok2 and zones then
                for _, z in ipairs(zones) do
                    local f = z:find_first_child(def.name)
                    if f then veh = f break end
                end
            end
        end
        if veh then
            entry.status = "spawned"
            local root = veh:find_first_child("HumanoidRootPart")
            if not root then
                local ok2, ch = pcall(function() return veh:get_children() end)
                if ok2 and ch then
                    for _, c in ipairs(ch) do if c:is_a("BasePart") then root = c break end end
                end
            end
            if mp and root then
                local okp, vp = pcall(function() return root.Position end)
                if okp and vp then entry.dist = math.floor(get_dist(mp.x,mp.y,mp.z,vp.x,vp.y,vp.z) * METERS_PER_STUD) end
            end
        end
        vehicle_data[i] = entry
    end
end

local function scan_mods()
    local found = {}
    local players = entity.get_players()
    local ws = game.workspace
    local psvc = game.players
    if players then
        for i = 1, #players do
            local p = players[i]
            if p and p.is_valid and p.name and not p.is_local then
                local lower = p.name:lower()
                local is_mod = MOD_NAMES[lower] and true or false
                local age = 0
                if psvc then
                    local psi = psvc:find_first_child(p.name)
                    if psi then local _, a = pcall(function() return psi.AccountAge end) age = a or 0 end
                end
                if is_mod or age < 30 then
                    found[#found+1] = { name = p.name, age = age, is_mod = is_mod }
                end
            end
        end
    end
    mod_list = found
end

local function scan_player_loot()
    local found = {}
    for _, d in ipairs(cached_players) do
        local p = d.entity
        if p and p.is_valid and p.is_alive and not p.is_local then
            local matched = {}
            for _, item in ipairs(d.inventory) do
                if is_valuable(item) or is_weapon(item) then matched[#matched+1] = item end
            end
            if #matched > 0 then found[#found+1] = { name = d.name, items = matched } end
        end
    end
    slf_results = found
end

