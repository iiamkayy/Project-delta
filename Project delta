function save_config()
    local ok,res=pcall(function()
        local path=get_config_path()
        local dir=path:match("^(.+)\\[^\\]+$")
        if dir then pcall(function() os.execute('mkdir "'..dir..'" 2>nul') end) end
        local file=io.open(path,"w")
        if not file then print("[Delta] Failed to save: "..path) return false end
        for _,item in ipairs(SAVE_ITEMS) do
            local v=sg(item.id)
            if item.t=="bool" then file:write(item.id.."="..(v and "1" or "0").."\n")
            elseif item.t=="int" then file:write(item.id.."="..tostring(tonumber(v) or 0).."\n") end
            if item.c then local c=sgc(item.id) file:write(item.id.."_color="..string.format("%.4f,%.4f,%.4f,%.4f",c[1],c[2],c[3],c[4]).."\n") end
            if item.k then file:write(item.id.."_key="..tostring(sgk(item.id)).."\n") end
        end
        file:close()
        print("[Delta] Config saved: "..path)
        return true
    end)
    if not ok then print("[Delta] Save error: "..tostring(res)) end
end

function load_config()
    local ok,res=pcall(function()
        local path=get_config_path()
        local file=io.open(path,"r")
        if not file then print("[Delta] No config found") return false end
        local data={}
        for line in file:lines() do
            local k,v=line:match("^([^=]+)=(.*)$")
            if k and v then data[k]=v end
        end
        file:close()
        for _,item in ipairs(SAVE_ITEMS) do
            local id=item.id
            if data[id] then
                if item.t=="bool" then pcall(function()menu.set(id,data[id]=="1")end)
                elseif item.t=="int" then pcall(function()menu.set(id,tonumber(data[id])or 0)end) end
            end
            if item.c and data[id.."_color"] then
                local r,g,b,a=data[id.."_color"]:match("([%d%.%-]+),([%d%.%-]+),([%d%.%-]+),([%d%.%-]+)")
                if r then pcall(function()menu.set_color(id,{tonumber(r),tonumber(g),tonumber(b),tonumber(a)})end) end
            end
            if item.k and data[id.."_key"] then pcall(function()menu.set_key(id,tonumber(data[id.."_key"])or 0)end) end
        end
        print("[Delta] Config loaded")
        return true
    end)
    if not ok then print("[Delta] Load error: "..tostring(res)) end
end

