-- MAIN FRAME
-- =============================================
function on_frame()
    cache_settings()
    refresh_npcs()
    refresh_world()

    -- Watermark
    draw_watermark()
    -- Crosshair
    draw_crosshair()
    -- Aimbot FOV
    if cfg.aim and cfg.aim_draw_fov then
        local mx,my=utility.get_mouse_pos()
        draw_fov_circle(mx,my,cfg.aim_fov,cfg.aim_fov_col,1)
    end

    local me=entity.get_local_player()
    local mp=me and me.position

    -- Player ESP
    if cfg.player then
        local players=entity.get_players()
        if players then
            for i=1,#players do
                local p=players[i]
                if p and p.is_valid and not p.is_local and p.is_alive then
                    local char=game.workspace:find_first_child(p.name)
                    if char then
                        local hum=char:find_first_child_of_class("Humanoid")
                        local root=char:find_first_child("HumanoidRootPart")
                        if hum and root then
                            local dist_m=0
                            if mp then
                                local ok,pos=pcall(function()return root.Position end)
                                if ok and pos then dist_m=math.floor(get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z)) end
                            end
                            if dist_m<=cfg.player_range then
                                draw_character_esp(char,p.name,hum,root,{
                                    box=cfg.player_box, box_col=cfg.player_box_col, box_style=cfg.player_box_style,
                                    skeleton=cfg.player_skel, skel_col=cfg.player_skel_col,
                                    health=cfg.player_hp, name=cfg.player_name, name_col=cfg.player_name_col,
                                    dist=cfg.player_dist, dist_col=cfg.player_dist_col, dist_m=dist_m,
                                    tracers=cfg.player_tracers, tracer_col=cfg.player_tracer_col,
                                })
                            end
                        end
                    end
                end
            end
        end
    end

    -- NPC ESP
    if cfg.npc then
        for _,npc in ipairs(npc_cache) do
            local root=npc.model:find_first_child("HumanoidRootPart")
            local dist_m=0
            if mp and root then
                local ok,pos=pcall(function()return root.Position end)
                if ok and pos then dist_m=math.floor(get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z)) end
            end
            if dist_m<=cfg.npc_range then
                draw_character_esp(npc.model,npc.model.name,npc.hum,root,{
                    box=cfg.npc_box, box_col=cfg.npc_box_col, box_style=cfg.npc_box_style,
                    skeleton=cfg.npc_skel, skel_col=cfg.npc_skel_col,
                    health=cfg.npc_hp, name=cfg.npc_name, name_col=cfg.npc_name_col,
                    dist=cfg.npc_dist, dist_col=cfg.npc_dist_col, dist_m=dist_m,
                    tracers=false,
                })
            end
        end
    end

    -- World ESP
    if cfg.extract then for _,item in ipairs(world_cache.extracts) do draw_world_item(item,cfg.extract_range,cfg.extract_col,cfg.extract_box,nil) end end
    if cfg.container then for _,item in ipairs(world_cache.containers) do draw_world_item(item,cfg.container_range,cfg.container_col,cfg.container_box,cfg.container_contents and item.contents or nil) end end
    if cfg.quest then for _,item in ipairs(world_cache.quests) do draw_world_item(item,cfg.quest_range,cfg.quest_col,cfg.quest_box,nil) end end
    if cfg.items then for _,item in ipairs(world_cache.items) do draw_world_item(item,cfg.items_range,cfg.items_col,cfg.items_box,nil) end end
    if cfg.corpse then for _,item in ipairs(world_cache.corpses) do draw_world_item(item,cfg.corpse_range,cfg.corpse_col,cfg.corpse_box,cfg.corpse_contents and item.contents or nil) end end
    if cfg.claymore then
        for _,item in ipairs(world_cache.claymores) do
            if cfg.claymore_names then
                draw_world_item(item,cfg.claymore_range,cfg.claymore_col,cfg.claymore_box,nil)
            else
                -- Just box, no text
                local ok,pos=pcall(function()return item.part.Position end)
                if ok and pos then
                    local dm=0
                    if mp then dm=math.floor(get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z)) end
                    if dm<=cfg.claymore_range and cfg.claymore_box then
                        local box=get_part_box(item.part)
                        if box then draw_oriented_box(box,cfg.claymore_col,1) end
                    end
                end
            end
        end
    end

    -- Aimbot
    process_aimbot()

    -- Panels
    draw_inv_panel()
    draw_boss_panel()
    draw_slf_panel()
    draw_mod_panel()
end

