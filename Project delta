function save_config()
    local ok, res = pcall(function()
        local path = get_config_path()
        local dir  = path:match("^(.+)\\[^\\]+$")
        if dir then pcall(function() os.execute('mkdir "' .. dir .. '" 2>nul') end) end
        local file = io.open(path, "w")
        if not file then print("[Delta] Failed to save: " .. path) return false end
        for _, it in ipairs(SAVE_ITEMS) do
            local v = sg(it.id)
            if it.t == "bool" then file:write(it.id .. "=" .. (v and "1" or "0") .. "\n")
            elseif it.t == "int" then file:write(it.id .. "=" .. tostring(tonumber(v) or 0) .. "\n") end
            if it.c then
                local c = sgc(it.id)
                file:write(it.id .. "_color=" .. string.format("%.4f,%.4f,%.4f,%.4f", c[1] or 1, c[2] or 1, c[3] or 1, c[4] or 1) .. "\n")
            end
            if it.k then file:write(it.id .. "_key=" .. tostring(sgk(it.id)) .. "\n") end
        end
        file:close()
        print("[Delta] Config saved: " .. path)
        return true
    end)
    if not ok then print("[Delta] Save error: " .. tostring(res)) end
end

function load_config()
    local ok, res = pcall(function()
        local path = get_config_path()
        local file = io.open(path, "r")
        if not file then print("[Delta] No config found") return false end
        local data = {}
        for line in file:lines() do
            local k, v = line:match("^([^=]+)=(.*)$")
            if k and v then data[k] = v end
        end
        file:close()
        for _, it in ipairs(SAVE_ITEMS) do
            local id = it.id
            if data[id] then
                if it.t == "bool" then pcall(function() menu.set(id, data[id] == "1") end)
                elseif it.t == "int" then pcall(function() menu.set(id, tonumber(data[id]) or 0) end) end
            end
            if it.c and data[id .. "_color"] then
                local r,g,b,a = data[id .. "_color"]:match("([%d%.%-]+),([%d%.%-]+),([%d%.%-]+),([%d%.%-]+)")
                if r then pcall(function() menu.set_color(id, { tonumber(r), tonumber(g), tonumber(b), tonumber(a) }) end) end
            end
            if it.k and data[id .. "_key"] then
                pcall(function() menu.set_key(id, tonumber(data[id .. "_key"]) or 0) end)
            end
        end
        print("[Delta] Config loaded")
        return true
    end)
    if not ok then print("[Delta] Load error: " .. tostring(res)) end
end

