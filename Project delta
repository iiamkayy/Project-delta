local function process_aimbot()
    if not cfg.aim or not input.is_key_down(0x02) then return end
    local mx,my=utility.get_mouse_pos()
    local fov=cfg.aim_fov; local best_target=nil; local best_dist=fov
    local bone_name=AIM_BONES[cfg.aim_bone]
    local me=entity.get_local_player(); local mp=me and me.position
    local cam_pos=camera.get_position()
    for _,npc in ipairs(npc_cache) do
        local ok,part=pcall(function()return npc.model:find_first_child(bone_name)end)
        if ok and part then
            local ok2,pos=pcall(function()return part.Position end)
            if ok2 and pos then
                if mp then
                    local d=get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z)
                    if d>cfg.npc_range then goto aim_skip end
                end
                local tx,ty,tz=pos.x,pos.y,pos.z
                if cfg.aim_pred then
                    local root=npc.model:find_first_child("HumanoidRootPart")
                    if root then
                        local ok3,vel=pcall(function()return root.Velocity end)
                        if ok3 and vel then
                            local d=get_dist(tx,ty,tz,cam_pos.x,cam_pos.y,cam_pos.z)
                            local tt=d/500
                            tx=tx+vel.x*tt; ty=ty+vel.y*tt; tz=tz+vel.z*tt
                        end
                    end
                end
                local sx,sy,vis=draw.world_to_screen(tx,ty,tz)
                if vis then
                    local dx,dy=sx-mx,sy-my; local dd=sqrt(dx*dx+dy*dy)
                    if dd<best_dist then best_dist=dd; best_target={x=sx,y=sy} end
                end
            end
        end
        ::aim_skip::
    end
    if best_target then
        local dx,dy=best_target.x-mx,best_target.y-my
        local strength=cfg.aim_smooth/20.0
        if math.abs(dx)<2000 and math.abs(dy)<2000 then input.move_mouse(dx*strength,dy*strength) end
    end
end

