local function draw_character_esp(model,display_name,hum,root,opts)
    local corners=get_model_bounds(model)
    if not corners then return end
    local anchors=get_box_anchors(corners)
    if not anchors.top.vis and not anchors.bot.vis then return end
    -- 3D Box
    if opts.box then
        if opts.box_style==1 then draw_3d_corner_box(corners,opts.box_col,1)
        else draw_3d_box(corners,opts.box_col,1) end
    end
    -- Skeleton
    if opts.skeleton then
        local scr={}
        for j=1,#BONE_NAMES do
            local ok,part=pcall(function()return model:find_first_child(BONE_NAMES[j])end)
            if ok and part then
                local ok2,pos=pcall(function()return part.Position end)
                if ok2 and pos then
                    local sx,sy,vis=draw.world_to_screen(pos.x,pos.y,pos.z)
                    scr[BONE_NAMES[j]]={x=sx,y=sy,vis=vis}
                end
            end
        end
        for j=1,#CONNECTIONS do
            local a,b=scr[CONNECTIONS[j][1]],scr[CONNECTIONS[j][2]]
            if a and b and a.vis and b.vis then draw.line(a.x,a.y,b.x,b.y,opts.skel_col,1) end
        end
    end
    -- Health Bar
    if opts.health and anchors.left.vis then
        local ok_h,hp=pcall(function()return hum.Health end)
        local ok_m,max_hp=pcall(function()return hum.MaxHealth end)
        if ok_h and ok_m and hp and max_hp and max_hp>0 then
            local ratio=hp/max_hp
            local bar_w,bar_x=4,anchors.left.x-8
            local bar_h=anchors.left.maxy-anchors.left.miny
            draw.rect_filled(bar_x,anchors.left.miny,bar_w,bar_h,{0.1,0.1,0.1,0.8},0)
            draw.rect_filled(bar_x,anchors.left.miny+bar_h-(bar_h*ratio),bar_w,bar_h*ratio,{1-ratio,ratio,0,1},0)
        end
    end
    -- Name
    if opts.name and anchors.top.vis then
        local tw=draw.get_text_size(display_name,FONT)
        text_nokia(anchors.top.x-(tw*0.5),anchors.top.y-FONT-2,display_name,opts.name_col,FONT)
    end
    -- Distance
    if opts.dist and anchors.bot.vis and opts.dist_m then
        local dt="["..opts.dist_m.."m]"
        local tw=draw.get_text_size(dt,FONT)
        text_nokia(anchors.bot.x-(tw*0.5),anchors.bot.y+2,dt,opts.dist_col,FONT)
    end
    -- Tracers
    if opts.tracers and root then
        local ok,pos=pcall(function()return root.Position end)
        if ok and pos then
            local sx,sy,vis=draw.world_to_screen(pos.x,pos.y,pos.z)
            if vis then
                local sw,sh=draw.get_screen_size()
                draw.line(sw*0.5,sh,sx,sy,opts.tracer_col,1)
            end
        end
    end
end

local function draw_world_item(item,range,color,show_box,contents)
    local ok,pos=pcall(function()return item.part.Position end)
    if not ok or not pos then return end
    local me=entity.get_local_player(); local mp=me and me.position
    local dist_m=0
    if mp then dist_m=math.floor(get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z)) end
    if dist_m>range then return end
    local sx,sy,vis=draw.world_to_screen(pos.x,pos.y,pos.z)
