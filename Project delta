local function draw_character_esp(model, display_name, hum, root, opts)
    local corners = get_model_bounds(model)
    if not corners then return end
    local anchors = get_box_anchors(corners)
    if not anchors.top.vis and not anchors.bot.vis then return end

    if opts.box then
        if opts.box_style == 1 then draw_3d_corner_box(corners, opts.box_col, 1)
        else draw_3d_box(corners, opts.box_col, 1) end
    end

    if opts.skeleton then
        local scr = {}
        for j = 1, #BONE_NAMES do
            local ok, part = pcall(function() return model:find_first_child(BONE_NAMES[j]) end)
            if ok and part then
                local ok2, pos = pcall(function() return part.Position end)
                if ok2 and pos then
                    local sx, sy, vis = draw.world_to_screen(pos.x, pos.y, pos.z)
                    if vis then scr[BONE_NAMES[j]] = { x = sx, y = sy } end
                end
            end
        end
        for j = 1, #BONE_CONNECTIONS do
            local a = scr[BONE_CONNECTIONS[j][1]]
            local b = scr[BONE_CONNECTIONS[j][2]]
            if a and b then draw.line(a.x, a.y, b.x, b.y, opts.skel_col, 1) end
        end
    end

    if opts.health and anchors.left.vis then
        local okh, hp   = pcall(function() return hum.Health end)
        local okm, mhp  = pcall(function() return hum.MaxHealth end)
        if okh and okm and hp and mhp and mhp > 0 then
            local ratio = hp / mhp
            local bar_w, bar_x = 4, anchors.left.x - 8
            local bar_h = anchors.left.maxy - anchors.left.miny
            draw.rect_filled(bar_x, anchors.left.miny, bar_w, bar_h, {0.1, 0.1, 0.1, 0.8}, 0)
            draw.rect_filled(bar_x, anchors.left.miny + bar_h - (bar_h*ratio), bar_w, bar_h*ratio, {1-ratio, ratio, 0, 1}, 0)
        end
    end

    if opts.name and anchors.top.vis then
        local tw = draw.get_text_size(display_name, FONT)
        draw.text(anchors.top.x - tw*0.5, anchors.top.y - FONT - 2, display_name, opts.name_col, FONT)
    end

    if opts.dist and anchors.bot.vis and opts.dist_m then
        local dt = "[" .. opts.dist_m .. "m]"
        local tw = draw.get_text_size(dt, FONT)
        draw.text(anchors.bot.x - tw*0.5, anchors.bot.y + 2, dt, opts.dist_col, FONT)
    end

    if opts.tracers and root then
        local ok, pos = pcall(function() return root.Position end)
        if ok and pos then
            local sx, sy, vis = draw.world_to_screen(pos.x, pos.y, pos.z)
            if vis then
                local sw, sh = draw.get_screen_size()
                draw.line(sw*0.5, sh, sx, sy, opts.tracer_col, 1)
            end
        end
    end
end

local function draw_world_item(item, range_m, color, show_box, contents)
    local ok, pos = pcall(function() return item.part.Position end)
    if not ok or not pos then return end
    local mp = get_local_pos()
    local dist_m = 0
    if mp then dist_m = get_dist(mp.x, mp.y, mp.z, pos.x, pos.y, pos.z) * METERS_PER_STUD end
    if dist_m > range_m then return end
    dist_m = math.floor(dist_m)
    local sx, sy, vis = draw.world_to_screen(pos.x, pos.y, pos.z)
    if not vis then return end
    local txt_y = sy
    if show_box then
        local box = get_part_box(item.part)
        if box then
            draw_oriented_box(box, color, 1)
            local top_x = box.x + box.ux*box.hy
            local top_y = box.y + box.uy*box.hy
            local top_z = box.z + box.uz*box.hy
            local _, ty, tvis = draw.world_to_screen(top_x, top_y, top_z)
            if tvis then txt_y = ty end
        end
    end
    local txt = item.name .. " [" .. dist_m .. "m]"
    local tw = draw.get_text_size(txt, FONT)
    draw.text(sx - tw*0.5, txt_y - FONT - 4, txt, color, FONT)
    if contents and #contents > 0 then
        for ci = 1, math.min(#contents, 5) do
            txt_y = txt_y + FONT + 1
            local ctw = draw.get_text_size(contents[ci], 11)
            draw.text(sx - ctw*0.5, txt_y - FONT, contents[ci], {0.8, 0.8, 0.8, 0.7}, 11)
        end
        if #contents > 5 then
            txt_y = txt_y + FONT + 1
            local mtxt = "+" .. (#contents-5) .. " more..."
            local mtw = draw.get_text_size(mtxt, 11)
            draw.text(sx - mtw*0.5, txt_y - FONT, mtxt, {0.6, 0.6, 0.6, 0.5}, 11)
        end
    end
end

local function draw_claymores()
    if not cfg.claymore then return end
    local mp = get_local_pos()
    for _, item in ipairs(world_cache.claymores) do
        local ok, pos = pcall(function() return item.part.Position end)
        if ok and pos then
            local dist_m = (mp and get_dist(mp.x,mp.y,mp.z,pos.x,pos.y,pos.z) * METERS_PER_STUD or 0)
            if dist_m <= cfg.claymore_range then
                local ok2, sz = pcall(function() return item.part.Size end)
                local hx = (sz and sz.x or 1) * 0.5
                local hy = (sz and sz.y or 1) * 0.5
                local hz = (sz and sz.z or 1) * 0.5
                local mnx,mny,mxx,mxy = math.huge, math.huge, -math.huge, -math.huge
                local valid = false
                for ox = -1, 1, 2 do for oy = -1, 1, 2 do for oz = -1, 1, 2 do
                    local sx, sy, vis = draw.world_to_screen(pos.x+hx*ox, pos.y+hy*oy, pos.z+hz*oz)
                    if vis then
                        valid = true
                        if sx < mnx then mnx = sx end if sx > mxx then mxx = sx end
                        if sy < mny then mny = sy end if sy > mxy then mxy = sy end
                    end
                end end end
                if valid then
                    local bw, bh = mxx-mnx, mxy-mny
                    draw.box(mnx, mny, bw, bh, cfg.claymore_col, 0, 0)
                    if cfg.claymore_names then
                        local txt = "Claymore [" .. math.floor(dist_m) .. "m]"
                        local tw = draw.get_text_size(txt, 13)
                        draw.text(mnx + (bw-tw)*0.5, mny - 16, txt, cfg.claymore_col, 13)
                    end
                end
                -- trigger beam
                if item.trigger then
                    local mx2, my2, mvis = draw.world_to_screen(pos.x, pos.y, pos.z)
                    if mvis then
                        local red = { 1, 0.15, 0.15, 1 }
                        local okp, tp = pcall(function() return item.trigger.Position end)
                        if okp and tp then
                            local tx2, ty2, tvis = draw.world_to_screen(tp.x, tp.y, tp.z)
                            if tvis then draw.line(mx2, my2, tx2, ty2, red, 2) end
                        end
                        local okc, tc = pcall(function() return item.trigger:get_children() end)
                        if okc and tc then
                            for _, tpart in ipairs(tc) do
                                if tpart:is_a("BasePart") then
                                    local okt, tpp = pcall(function() return tpart.Position end)
                                    if okt and tpp then
                                        local tx3, ty3, tv3 = draw.world_to_screen(tpp.x, tpp.y, tpp.z)
                                        if tv3 then draw.line(mx2, my2, tx3, ty3, red, 2) end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

