local function get_inv_contents(model)
    local ok, inv = pcall(function() return model:find_first_child("Inventory") end)
    if not ok or not inv then return nil end
    local ok2, ch = pcall(function() return inv:get_children() end)
    if not ok2 or not ch or #ch == 0 then return nil end
    local counts = {}
    for i = 1, #ch do
        local n = ch[i].name
        if n and n ~= "" then counts[n] = (counts[n] or 0) + 1 end
    end
    local out = {}
    for n, c in pairs(counts) do out[#out+1] = c > 1 and (n .. " x" .. c) or n end
    return #out > 0 and out or nil
end

