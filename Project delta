local SLF_TITLE_H = 24
local SLF_PAD     = 8
local SLF_LINE_H  = 16
local SLF_FONT    = 13
local SLF_FONT_S  = 11

local slf_col_bg      = { 0.05, 0.05, 0.07, 0.96 }
local slf_col_title   = { 0.07, 0.07, 0.10, 1.00 }
local slf_col_border  = { 0.18, 0.72, 0.84, 1.00 }
local slf_col_accent  = { 0.18, 0.72, 0.84, 1.00 }
local slf_col_dim     = { 0.25, 0.25, 0.30, 1.00 }
local slf_col_player  = { 1.00, 1.00, 1.00, 1.00 }
local slf_col_item    = { 0.35, 0.90, 0.45, 1.00 }
local slf_col_none    = { 0.45, 0.45, 0.50, 1.00 }
local slf_col_sep     = { 0.18, 0.72, 0.84, 0.3  }

