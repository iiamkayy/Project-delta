local sqrt, format = math.sqrt, string.format

local function get_dist(x1,y1,z1,x2,y2,z2)
    local dx,dy,dz = x1-x2, y1-y2, z1-z2
    return sqrt(dx*dx + dy*dy + dz*dz)
end

local function get_root(model)
    if not model then return nil end
    return model:find_first_child("Root")
        or model:find_first_child("MainPart")
        or model:find_first_child_of_class("BasePart")
end

local function is_weapon(n)   local l=n:lower() for _,p in ipairs(weapons_list)   do if l:find(p:lower(),1,true) then return true end end return false end
local function is_armor(n)    local l=n:lower() for _,p in ipairs(armor_list)     do if l:find(p:lower(),1,true) then return true end end return false end
local function is_valuable(n) local l=n:lower() for _,p in ipairs(valuables_list) do if l:find(p:lower(),1,true) then return true end end return false end

local function get_item_color(n)
    if is_valuable(n) then return COL.val end
    if is_weapon(n)   then return COL.gun end
    if is_armor(n)    then return COL.armor end
    return COL.junk
end

local function get_local_pos()
    local me = entity.get_local_player()
    if me and me.position then return me.position end
    local cp = camera.get_position()
    return cp
end

