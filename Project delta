-- AIMBOT
-- =====================================================================
local function process_aimbot()
    if not cfg.aim then return end
    if cfg.aim_draw_fov then
        local scx, scy = input.get_screen_center()
        draw_fov_circle(scx, scy, cfg.aim_fov, cfg.aim_fov_col, 1)
    end
    local key = sgk("delta_npc_aim_enabled")
    if key == 0 then key = 0x02 end
    if not input.is_key_down(key) then return end

    local scx, scy = input.get_screen_center()
    local bone_name = AIM_BONES[cfg.aim_bone] or "Head"
    local best_dist = cfg.aim_fov
    local best_tx, best_ty
    local cam = camera.get_position()

    for _, npc in ipairs(npc_cache) do
        local ok, part = pcall(function() return npc.model:find_first_child(bone_name) end)
        if ok and part then
            local ok2, pos = pcall(function() return part.Position end)
            if ok2 and pos then
                local tx, ty, tz = pos.x, pos.y, pos.z
                if cfg.aim_pred then
                    local root = npc.model:find_first_child("HumanoidRootPart")
                    if root then
                        local ok3, vel = pcall(function() return root.Velocity end)
                        if ok3 and vel and cam then
                            local d = get_dist(tx,ty,tz, cam.x, cam.y, cam.z)
                            local tt = d / 500
                            tx = tx + vel.x * tt
                            ty = ty + vel.y * tt
                            tz = tz + vel.z * tt
                        end
                    end
                end
                local sx, sy, vis = draw.world_to_screen(tx, ty, tz)
                if vis then
                    local dd = sqrt((sx-scx)^2 + (sy-scy)^2)
                    if dd < best_dist then best_dist = dd best_tx = sx best_ty = sy end
                end
            end
        end
    end

    if best_tx and best_ty then
        local dx = best_tx - scx
        local dy = best_ty - scy
        local strength = cfg.aim_smooth / 20.0
        if math.abs(dx) < 2000 and math.abs(dy) < 2000 then
            input.move_mouse(dx * strength, dy * strength)
        end
    end
end

