local function scan_players_inv()
    local now=utility.get_tick_count()
    if now-cached_inv_time<800 and #cached_players>0 then return end
    cached_inv_time=now; cached_players={}
    local players=entity.get_players()
    if not players then return end
    local rep=game.get_service("ReplicatedStorage")
    local rep_players=rep and rep:find_first_child("Players")
    for i=1,#players do
        local p=players[i]
        if p and p.is_valid and not p.is_local then
            local pname=p.name or ""
            local puid=tostring(p.user_id or "")
            local inv={}; local worn={}; local seen={}
            local equipped=nil
            local function add(n,is_top) if n~="" and not seen[n] then seen[n]=true; inv[#inv+1]=n; if is_top then worn[n]=true end end end
            local function scan_folder(folder,depth)
                if not folder or (depth and depth>8) then return end
                local ok2,items=pcall(function()return folder:get_children()end)
                if not ok2 or not items then return end
                for j=1,#items do
                    local item=items[j]; local n=item.name or ""
                    if n~="" then add(n,depth==0) end
                    local ok3,ch=pcall(function()return item:get_children()end)
                    if ok3 and ch and #ch>0 then scan_folder(item,(depth or 0)+1) end
                end
            end
            if rep_players then
                local data=rep_players:find_first_child(pname)
                if not data and puid~="" then data=rep_players:find_first_child(puid) end
                if data then
                    scan_folder(data:find_first_child("Inventory"),0)
                    local status=data:find_first_child("Status")
                    if status then
                        local gv=status:find_first_child("GameplayVariables")
                        if gv then
                            local eq=gv:find_first_child("EquippedTool")
                            if eq and eq.Value then
                                local v=eq.Value
                                equipped=type(v)=="string" and v~="" and v or (type(v)=="userdata" and v.name or nil)
                            end
                        end
                    end
                end
            end
            cached_players[#cached_players+1]={name=pname,entity=p,inventory=inv,worn=worn,equipped=equipped}
        end
    end
end

local function update_bosses()
    local ws=game.workspace
    if not ws then return end
    local ai_zones=ws:find_first_child("AiZones")
    for i,def in ipairs(boss_defs) do
        local entry={name=def.name,status="none",hp=0,max_hp=0,dist=-1}
        if ai_zones then
            local zone=ai_zones:find_first_child(def.zone)
            local boss=zone and zone:find_first_child(def.name)
            if boss then
                local hum=boss:find_first_child_of_class("Humanoid")
                if hum then
                    local hp=hum.Health; local max_hp=hum.MaxHealth
                    if hp and hp>0 then
                        entry.status="alive"; entry.hp=math.floor(hp); entry.max_hp=math.floor(max_hp)
                        local me=entity.get_local_player()
                        local hrp=boss:find_first_child("HumanoidRootPart")
                        if me and hrp then
                            local mp=me.position; local bp=hrp.Position
                            if mp and bp then entry.dist=math.floor(get_dist(mp.x,mp.y,mp.z,bp.x,bp.y,bp.z)) end
                        end
                    else entry.status="dead" end
                else entry.status="dead" end
            end
        end
        boss_data[i]=entry
    end
    for i,def in ipairs(vehicle_defs) do
        local entry={name=def.label,status="none",dist=-1}
        local veh=ws:find_first_child(def.name)
        if not veh and ai_zones then
            local ok2,zones=pcall(function()return ai_zones:get_children()end)
            if ok2 and zones then for _,z in ipairs(zones) do local f=z:find_first_child(def.name) if f then veh=f break end end end
        end
        if veh then
            entry.status="spawned"
            local root=veh:find_first_child("HumanoidRootPart")
            if not root then
                local ok2,ch=pcall(function()return veh:get_children()end)
                if ok2 and ch then for _,c in ipairs(ch) do if c:is_a("BasePart") then root=c break end end end
            end
            local me=entity.get_local_player()
            if me and root then
                local mp=me.position; local vp=root.Position
                if mp and vp then entry.dist=math.floor(get_dist(mp.x,mp.y,mp.z,vp.x,vp.y,vp.z)) end
            end
        end
        vehicle_data[i]=entry
    end
end

