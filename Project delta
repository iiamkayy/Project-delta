local patternNames = { "RecoilPattern", "RecoilPatternOLD", "RecoilPattern2", "RecoilPattern3", "RecoilPatternDisabled" }

local function zero_recoil()
    if not safe_menu_get("delta_norecoil_enabled") then return end
    local rep = game.ReplicatedStorage
    if not rep then return end
    local rw = rep:find_first_child("RangedWeapons")
    if not rw then return end
    local weapons = rw:get_children()
    for i = 1, #weapons do
        local w = weapons[i]
        for n = 1, #patternNames do
            local p = w:find_first_child(patternNames[n])
            if p then
                local shots = p:get_children()
                for j = 1, #shots do
                    local xv = shots[j]:find_first_child("x")
                    local yv = shots[j]:find_first_child("y")
                    if xv then xv.value = 0 end
                    if yv then yv.value = 0 end
                end
            end
        end
    end
end


